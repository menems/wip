# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

# PostgreSQL connection string (DSN format)
DATABASE_URL=postgres://saas:saas@localhost:5432/saas?sslmode=disable

# HS256 signing secret — MUST be at least 32 characters. Change before deploy.
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Token TTLs (Go duration strings)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

# HTTP server port
PORT=8080

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# Backend base URL (used by Vite proxy in dev, nginx upstream in prod)
VITE_API_URL=http://localhost:8080
